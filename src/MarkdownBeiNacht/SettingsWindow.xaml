<Window x:Class="MarkdownBeiNacht.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Theme Settings"
        Width="430"
        Height="290"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#091120"
        Foreground="#EAF2FF"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Midnight Theme"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />

        <TextBlock Grid.Row="1"
                   Text="Choose the base dark navy tone used throughout the preview."
                   TextWrapping="Wrap"
                   Foreground="#C1D2E2"
                   Margin="0,0,0,18" />

        <Border Grid.Row="2"
                CornerRadius="18"
                Padding="18"
                BorderBrush="#294362"
                BorderThickness="1"
                Background="#0D1728">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="ColorSwatch"
                        Width="56"
                        Height="56"
                        CornerRadius="14"
                        BorderBrush="#5D7FA3"
                        BorderThickness="1" />
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="Base Color"
                               FontSize="13"
                               Foreground="#9BB4CB" />
                    <TextBlock x:Name="ColorValueText"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,22,0,0">
            <Button Content="Default"
                    Width="86"
                    Margin="0,0,10,0"
                    Click="ResetButton_OnClick" />
            <Button Content="Choose Color..."
                    Width="118"
                    Margin="0,0,10,0"
                    Click="ChooseColorButton_OnClick" />
            <Button Content="Cancel"
                    Width="86"
                    Margin="0,0,10,0"
                    IsCancel="True" />
            <Button Content="Save"
                    Width="86"
                    IsDefault="True"
                    Click="SaveButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>

