<Window x:Class="MarkdownBeiNacht.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Markdown bei Nacht"
        Icon="Assets/AppIcon.ico"
        Width="1280"
        Height="900"
        MinWidth="900"
        MinHeight="640"
        Background="#06101D"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_OnLoaded"
        Closed="Window_OnClosed"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        AllowDrop="True"
        PreviewDragEnter="Window_OnPreviewDragOver"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDragLeave="Window_OnPreviewDragLeave"
        Drop="Window_OnDrop">
    <DockPanel>
        <Menu x:Name="MainMenu" DockPanel.Dock="Top"
              Background="#091120"
              Foreground="#E5F1FF"
              Padding="6,4">
            <Menu.Resources>
                <SolidColorBrush x:Key="MenuBarForegroundBrush" Color="#E5F1FF" />
                <SolidColorBrush x:Key="MenuBarHighlightBrush" Color="#14263A" />
                <SolidColorBrush x:Key="MenuPopupBackgroundBrush" Color="#0E1829" />
                <SolidColorBrush x:Key="MenuPopupForegroundBrush" Color="#EAF3FF" />
                <SolidColorBrush x:Key="MenuPopupBorderBrush" Color="#253A56" />
                <SolidColorBrush x:Key="MenuPopupHighlightBrush" Color="#18314A" />
                <SolidColorBrush x:Key="MenuPopupDisabledBrush" Color="#6F8197" />

                <Style x:Key="TopLevelMenuItemStyle" TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource MenuBarForegroundBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="10,4" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="RootBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                           PopupAnimation="Fade">
                                        <Border Background="{DynamicResource MenuPopupBackgroundBrush}"
                                                BorderBrush="{DynamicResource MenuPopupBorderBrush}"
                                                BorderThickness="1"
                                                Padding="4"
                                                SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource MenuBarHighlightBrush}" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource MenuBarHighlightBrush}" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="SubmenuMenuItemStyle" TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource MenuPopupForegroundBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="12,8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border Background="{DynamicResource MenuPopupBackgroundBrush}"
                                        BorderBrush="{DynamicResource MenuPopupBorderBrush}"
                                        BorderThickness="0">
                                    <Grid MinWidth="180">
                                        <Border x:Name="ItemBackground"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  ContentSource="Header"
                                                                  RecognizesAccessKey="True"
                                                                  VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{TemplateBinding InputGestureText}"
                                                           Margin="24,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource MenuPopupHighlightBrush}" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource MenuPopupDisabledBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="NestedSubmenuMenuItemStyle" TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource MenuPopupForegroundBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="12,8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border Background="{DynamicResource MenuPopupBackgroundBrush}"
                                            BorderBrush="{DynamicResource MenuPopupBorderBrush}"
                                            BorderThickness="0">
                                        <Grid MinWidth="180">
                                            <Border x:Name="ItemBackground"
                                                    Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0"
                                                                      ContentSource="Header"
                                                                      RecognizesAccessKey="True"
                                                                      VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="&#x203A;"
                                                               Margin="24,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{TemplateBinding Foreground}" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Right"
                                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                           PopupAnimation="Fade">
                                        <Border Background="{DynamicResource MenuPopupBackgroundBrush}"
                                                BorderBrush="{DynamicResource MenuPopupBorderBrush}"
                                                BorderThickness="1"
                                                Padding="4"
                                                SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource MenuPopupHighlightBrush}" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource MenuPopupHighlightBrush}" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource MenuPopupDisabledBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="ContextMenu">
                    <Setter Property="Background" Value="{DynamicResource MenuPopupBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MenuPopupForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource MenuPopupBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="4" />
                </Style>

                <Style TargetType="Separator">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Separator">
                                <Border Height="1"
                                        Margin="8,4"
                                        Background="{DynamicResource MenuPopupBorderBrush}" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Menu.Resources>
            <MenuItem Header="_File" Style="{StaticResource TopLevelMenuItemStyle}">
                <MenuItem Header="_Open..."
                          Style="{StaticResource SubmenuMenuItemStyle}"
                          Click="OpenMenuItem_OnClick"
                          InputGestureText="Ctrl+O" />
                <MenuItem x:Name="RecentFilesMenuItem"
                          Header="_Recent Files"
                          Style="{StaticResource NestedSubmenuMenuItemStyle}"
                          SubmenuOpened="RecentFilesMenuItem_OnSubmenuOpened" />
                <Separator />
                <MenuItem Header="E_xit"
                          Style="{StaticResource SubmenuMenuItemStyle}"
                          Click="ExitMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="_View" Style="{StaticResource TopLevelMenuItemStyle}">
                <MenuItem Header="_Reload"
                          Style="{StaticResource SubmenuMenuItemStyle}"
                          Click="ReloadMenuItem_OnClick"
                          InputGestureText="F5" />
                <MenuItem Header="_Settings..."
                          Style="{StaticResource SubmenuMenuItemStyle}"
                          Click="SettingsMenuItem_OnClick"
                          InputGestureText="Ctrl+," />
            </MenuItem>
            <MenuItem Header="_Help" Style="{StaticResource TopLevelMenuItemStyle}">
                <MenuItem Header="_User Guide"
                          Style="{StaticResource SubmenuMenuItemStyle}"
                          Click="UserGuideMenuItem_OnClick"
                          InputGestureText="F1" />
            </MenuItem>
        </Menu>

        <Grid x:Name="RootGrid" Background="#06101D">
            <wv2:WebView2CompositionControl x:Name="PreviewWebView"
                                            AllowDrop="True"
                                            AllowExternalDrop="False"
                                            PreviewDragEnter="Window_OnPreviewDragOver"
                                            PreviewDragOver="Window_OnPreviewDragOver"
                                            PreviewDragLeave="Window_OnPreviewDragLeave"
                                            Drop="Window_OnDrop"
                                            Visibility="Hidden"
                                            IsHitTestVisible="False"
                                            DefaultBackgroundColor="#06101D" />

            <Border x:Name="StatePanel"
                    Margin="32"
                    Padding="32"
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="24"
                    Background="#0B1424"
                    BorderBrush="#1C2B42"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="StateEyebrowText"
                               Text="Markdown bei Nacht"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#6DC6FF"
                               Margin="0,0,0,10" />
                    <TextBlock x:Name="StateTitleText"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#F4F8FF"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <TextBlock x:Name="StateMessageText"
                               FontSize="15"
                               Foreground="#C0D0E0"
                               TextWrapping="Wrap"
                               Margin="0,0,0,22"
                               LineHeight="24" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="StateOpenButton"
                                Content="Open File"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"
                                Click="OpenFileButton_OnClick" />
                        <TextBlock x:Name="StateHintText"
                                   VerticalAlignment="Center"
                                   Foreground="#8AA0B8"
                                   Text="or drag a .md file here" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="DropOverlay"
                    Visibility="Collapsed"
                    Margin="24"
                    CornerRadius="28"
                    Background="#A0091320"
                    BorderBrush="#7A2B4B6A"
                    BorderThickness="2"
                    IsHitTestVisible="False">
                <Border x:Name="DropOverlayInnerBorder"
                        Margin="18"
                        CornerRadius="22"
                        BorderBrush="#6685B5D9"
                        BorderThickness="2"
                        Background="#33091320">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="DropOverlayTitleText" Text="Drop Markdown File"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#F3F8FF"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6" />
                        <TextBlock x:Name="DropOverlayMessageText" Text="Drop a .md, .markdown, or .mdown file to open it"
                                   FontSize="15"
                                   Foreground="#C4D6E7"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</Window>
