<Window x:Class="MarkdownBeiNacht.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Markdown bei Nacht"
        Width="1280"
        Height="900"
        MinWidth="900"
        MinHeight="640"
        Background="#06101D"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_OnLoaded"
        Closed="Window_OnClosed"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        AllowDrop="True"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDragLeave="Window_OnPreviewDragLeave"
        Drop="Window_OnDrop">
    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="#091120"
              Foreground="#E5F1FF"
              Padding="6,4">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..."
                          Click="OpenMenuItem_OnClick"
                          InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="E_xit" Click="ExitMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Reload"
                          Click="ReloadMenuItem_OnClick"
                          InputGestureText="F5" />
                <MenuItem Header="_Settings..."
                          Click="SettingsMenuItem_OnClick"
                          InputGestureText="Ctrl+," />
            </MenuItem>
        </Menu>

        <Grid Background="#06101D">
            <wv2:WebView2 x:Name="PreviewWebView"
                          Visibility="Collapsed"
                          DefaultBackgroundColor="#06101D" />

            <Border x:Name="StatePanel"
                    Margin="32"
                    Padding="32"
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="24"
                    Background="#0B1424"
                    BorderBrush="#1C2B42"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="StateEyebrowText"
                               Text="Markdown bei Nacht"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#6DC6FF"
                               Margin="0,0,0,10" />
                    <TextBlock x:Name="StateTitleText"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#F4F8FF"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <TextBlock x:Name="StateMessageText"
                               FontSize="15"
                               Foreground="#C0D0E0"
                               TextWrapping="Wrap"
                               Margin="0,0,0,22"
                               LineHeight="24" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="StateOpenButton"
                                Content="Open File"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"
                                Click="OpenFileButton_OnClick" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#8AA0B8"
                                   Text="or drag a .md file into this window" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="DropOverlay"
                    Visibility="Collapsed"
                    Margin="24"
                    CornerRadius="28"
                    Background="#A0091320"
                    BorderBrush="#7A2B4B6A"
                    BorderThickness="2"
                    IsHitTestVisible="False">
                <Border Margin="18"
                        CornerRadius="22"
                        BorderBrush="#6685B5D9"
                        BorderThickness="2"
                        Background="#33091320">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Drop Markdown File"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#F3F8FF"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Open a .md, .markdown, or .mdown file in this window"
                                   FontSize="15"
                                   Foreground="#C4D6E7"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</Window>

